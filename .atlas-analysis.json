  "keyFeatures": [
    "REST Trading API with authenticated order management (create, cancel, amend orders)",
    "Public market data endpoints (markets, orderbook, trades, index prices, candles)",
    "WebSocket streams for real-time market data and private account updates",
    "ECDSA and HMAC API key authentication with JWT bearer tokens",
    "Custody endpoints for crypto and fiat deposits/withdrawals",
    "AMM (Automated Market Making) instruction management",
    "Derivatives positions, perpetuals, and options support",
    "OTC (Over-The-Counter) trade execution",
    "Aggregator API for public tickers, orderbook depth, and recent trades",
    "FIX protocol support for institutional clients via private connectivity",
    "Market Maker Protection (MMP) configuration",
    "Portfolio margin simulator"
  ],
